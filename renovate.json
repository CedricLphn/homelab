{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "kubernetes": {
    "managerFilePatterns": [
      "/\\.yaml$/",
      "/\\.yml$/"
    ]
  },
  "packageRules": [
    {
      "description": "Pin Immich PostgreSQL to v14 with VectorChord (critical dependency)",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "ghcr.io/immich-app/postgres"
      ],
      "enabled": false
    },
    {
      "description": "Track Immich app versions (semver)",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "ghcr.io/immich-app/immich-server",
        "ghcr.io/immich-app/immich-machine-learning"
      ],
      "versioning": "semver"
    },
    {
      "description": "Track Miniflux and Paperless versions (semver)",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "ghcr.io/paperless-ngx/paperless-ngx",
        "miniflux/miniflux"
      ],
      "versioning": "semver"
    },
    {
      "description": "Track Apache Tika latest tag",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "apache/tika"
      ],
      "followTag": "latest"
    },
    {
      "description": "Track gotenberg major version 8",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["gotenberg/gotenberg"],
      "allowedVersions": "/^8\\./",
      "versioning": "semver"
    },
    {
      "description": "Track rsshub chromium-bundled variant",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["diygod/rsshub"],
      "allowedVersions": "/-chromium-bundled$/",
      "versioning": "loose"
    }
  ]
}
